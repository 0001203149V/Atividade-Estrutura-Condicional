let num = 15;
if (num % 3 === 0 && num % 5 === 0) {
    console.log(`${num} é divisível por ambos (3 e 5)`);
}else if (num % 3 === 0){
    console.log(`${num} é divisível por 3`);
}else if (num % 5 === 0){
    console.log(`${num} é divisível por 5`);
}else{
    console.log(`${num} não é divisível nem por 3 nem por 5`);
}
